{
  "name": "calendar-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 Sovereign AI tools for everyone.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "create_event",
      "description": "Create a calendar event. start/end in ISO 8601 format (YYYY-MM-DDTHH:MM:SS).",
      "parameters": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "start": {
            "type": "string"
          },
          "end": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "attendees": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "start",
          "end"
        ]
      }
    },
    {
      "name": "find_free_slot",
      "description": "Find free time slots. busy_slots: JSON array of {start, end} objects. date: YYYY-MM-DD.",
      "parameters": {
        "type": "object",
        "properties": {
          "busy_slots": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "duration_minutes": {
            "type": "integer"
          },
          "work_start": {
            "type": "string"
          },
          "work_end": {
            "type": "string"
          }
        },
        "required": [
          "busy_slots",
          "date"
        ]
      }
    },
    {
      "name": "calculate_duration",
      "description": "Calculate duration between two ISO 8601 datetime strings.",
      "parameters": {
        "type": "object",
        "properties": {
          "start": {
            "type": "string"
          },
          "end": {
            "type": "string"
          }
        },
        "required": [
          "start",
          "end"
        ]
      }
    },
    {
      "name": "timezone_convert",
      "description": "Convert time between UTC offsets. Offsets in hours (e.g., -5 for EST, +1 for CET).",
      "parameters": {
        "type": "object",
        "properties": {
          "datetime_str": {
            "type": "string"
          },
          "from_offset": {
            "type": "number"
          },
          "to_offset": {
            "type": "number"
          }
        },
        "required": [
          "datetime_str",
          "from_offset",
          "to_offset"
        ]
      }
    }
  ]
}